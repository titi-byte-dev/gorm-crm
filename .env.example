# Ambiente
ENV=development           # development | production

# Servidor
PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gorm_crm
DB_SSLMODE=disable

# MongoDB (opcional — desativa activity log se não configurado)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=gorm_crm

# JWT — obrigatório em produção
JWT_SECRET=dev-secret-change-in-production

# Agent Mode (opcional — usa fallback rule-based se não configurado)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
