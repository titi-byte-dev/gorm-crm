{
  "$schema": "https://design-tokens.org/schema/1.0.0",
  "meta": {
    "product": "GoRM CRM",
    "version": "1.0.0",
    "description": "Design tokens do GoRM CRM. Framework-agnostic — consumível por qualquer frontend (React, Vue, HTMX, etc.)"
  },

  "color": {
    "brand": {
      "primary":   { "value": "#0F62FE", "comment": "Azul IBM — profissional, confiável, técnico" },
      "secondary": { "value": "#6929C4", "comment": "Violeta — diferenciador, energia" },
      "accent":    { "value": "#00B4D8", "comment": "Ciano — links, hover states, highlights" }
    },

    "pipeline": {
      "new":         { "value": "#6B7280", "comment": "Lead novo — neutro, ainda não avaliado" },
      "contacted":   { "value": "#3B82F6", "comment": "Em contacto — ativo, azul" },
      "qualified":   { "value": "#F59E0B", "comment": "Qualificado — quente, atenção" },
      "proposal":    { "value": "#8B5CF6", "comment": "Proposta enviada — próximo do fecho" },
      "negotiation": { "value": "#EC4899", "comment": "Negociação — urgente, foco" },
      "won":         { "value": "#10B981", "comment": "Ganho — verde sucesso" },
      "lost":        { "value": "#EF4444", "comment": "Perdido — vermelho claro, não agressivo" }
    },

    "priority": {
      "low":    { "value": "#9CA3AF" },
      "medium": { "value": "#3B82F6" },
      "high":   { "value": "#F59E0B" },
      "urgent": { "value": "#EF4444" }
    },

    "role": {
      "admin":   { "value": "#6929C4", "comment": "Admin — violeta, autoridade" },
      "manager": { "value": "#0F62FE", "comment": "Manager — azul, liderança" },
      "seller":  { "value": "#00B4D8", "comment": "Seller — ciano, dinâmico" }
    },

    "semantic": {
      "success":  { "value": "#10B981" },
      "warning":  { "value": "#F59E0B" },
      "error":    { "value": "#EF4444" },
      "info":     { "value": "#3B82F6" }
    },

    "neutral": {
      "50":  { "value": "#F9FAFB" },
      "100": { "value": "#F3F4F6" },
      "200": { "value": "#E5E7EB" },
      "300": { "value": "#D1D5DB" },
      "400": { "value": "#9CA3AF" },
      "500": { "value": "#6B7280" },
      "600": { "value": "#4B5563" },
      "700": { "value": "#374151" },
      "800": { "value": "#1F2937" },
      "900": { "value": "#111827" }
    },

    "background": {
      "base":    { "value": "#FFFFFF" },
      "subtle":  { "value": "#F9FAFB" },
      "muted":   { "value": "#F3F4F6" },
      "inverse": { "value": "#111827" }
    }
  },

  "typography": {
    "font": {
      "sans":  { "value": "'Inter', 'system-ui', sans-serif" },
      "mono":  { "value": "'JetBrains Mono', 'Fira Code', monospace" }
    },
    "size": {
      "xs":   { "value": "12px" },
      "sm":   { "value": "14px" },
      "base": { "value": "16px" },
      "lg":   { "value": "18px" },
      "xl":   { "value": "20px" },
      "2xl":  { "value": "24px" },
      "3xl":  { "value": "30px" },
      "4xl":  { "value": "36px" }
    },
    "weight": {
      "normal":   { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" },
      "bold":     { "value": "700" }
    },
    "lineHeight": {
      "tight":  { "value": "1.25" },
      "normal": { "value": "1.5" },
      "relaxed":{ "value": "1.75" }
    }
  },

  "spacing": {
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" }
  },

  "radius": {
    "sm":   { "value": "4px" },
    "base": { "value": "6px" },
    "md":   { "value": "8px" },
    "lg":   { "value": "12px" },
    "xl":   { "value": "16px" },
    "full": { "value": "9999px" }
  },

  "shadow": {
    "sm":  { "value": "0 1px 2px 0 rgb(0 0 0 / 0.05)" },
    "base":{ "value": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)" },
    "md":  { "value": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)" },
    "lg":  { "value": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)" }
  },

  "breakpoint": {
    "sm":  { "value": "640px" },
    "md":  { "value": "768px" },
    "lg":  { "value": "1024px" },
    "xl":  { "value": "1280px" },
    "2xl": { "value": "1536px" }
  }
}
